{
  "name": "ritmo-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@ritmo/web",
    "dev:api": "turbo dev --filter=@ritmo/api",
    "dev:landing": "turbo dev --filter=@ritmo/landing",
    "build": "turbo build",
    "build:web": "turbo build --filter=@ritmo/web",
    "build:api": "turbo build --filter=@ritmo/api",
    "start": "nuxt start",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "turbo db:seed",
    "db:reset": "prisma migrate reset --force",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker-compose logs -f",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test -- --coverage",
    "lint": "turbo lint",
    "format": "turbo format",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "setup": "pnpm docker:up && sleep 5 && pnpm db:migrate && pnpm db:seed",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.17",
    "@fullcalendar/daygrid": "^6.1.17",
    "@fullcalendar/interaction": "^6.1.17",
    "@fullcalendar/list": "^6.1.17",
    "@fullcalendar/timegrid": "^6.1.17",
    "@fullcalendar/vue3": "^6.1.17",
    "@nuxtjs/i18n": "^9.5.6",
    "@nuxtjs/tailwindcss": "^6.10.0",
    "@pinia/nuxt": "^0.4.11",
    "@prisma/client": "^6.11.0",
    "@prisma/extension-accelerate": "^2.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.6.5",
    "zod": "^3.22.4",
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-vue-next": "^0.525.0",
    "nuxt": "^3.17.5",
    "pinia": "^2.1.7",
    "prisma": "^6.11.0",
    "vue": "^3.5.21",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.9",
    "@nuxt/devtools": "^2.6.3",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/eslint-module": "^4.1.0",
    "@rushstack/eslint-patch": "^1.3.3",
    "@types/node": "^24.3.1",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-typescript": "^14.6.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-vue": "^10.4.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.4",
    "prettier-plugin-vue": "^1.1.6",
    "tsx": "^4.7.0",
    "turbo": "^2.3.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "dotenv": "^17.2.2",
    "bundle-analyzer": "^0.0.6",
    "lighthouse-ci": "^1.13.1",
    "vitepress": "^1.0.0-rc.31"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "tsc --noEmit"
    ]
  },
  "packageManager": "pnpm@9.15.0"
}
